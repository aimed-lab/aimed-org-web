# Example environment variables for aimed-lab.org.
# Copy relevant entries into .env.local (dev) or the Vercel dashboard (prod).
# Do NOT put real secrets in this file — it is committed to git.

# ── Database (local dev; production rebuilds from data/*.tsv) ──
DATABASE_URL="file:./aimeddata.db"

# ── AI CV parsing (Google Gemini) ──
GEMINI_API_KEY="your-gemini-api-key"

# ── CV staging → preview → accept workflow (see CV-WORKFLOW.md) ──
# GitHub token with "Contents: Read and write" on the site repo.
# Required for the admin "Stage & Preview / Accept" flow to work.
GITHUB_TOKEN="github_pat_xxxxxxxxxxxxxxxx"
# Optional overrides (defaults shown):
# GITHUB_REPO="aimed-lab/aimed-org-web"
# GITHUB_BASE_BRANCH="main"
# CV_PREVIEW_URL=""   # fallback preview URL if the live one can't be auto-detected

# ── Transactional email (Resend) ──
RESEND_API_KEY="your-resend-api-key"

# ── Box integration (optional) ──
BOX_CLIENT_ID="your-box-client-id"
BOX_DEVELOPER_TOKEN="your-box-developer-token"
