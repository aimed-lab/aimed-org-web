// Prisma schema for the AI.MED Lab website
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Models ────────────────────────────────��─────────────────────────────────
// Note: SQLite doesn't support enums. Using String fields with app-level validation.
// AppointmentType values: EDUCATION, FACULTY, INDUSTRY, VISITING
// InquiryStatus values: NEW, REVIEWED, REPLIED, SHORTLISTED, ACCEPTED, DECLINED, ARCHIVED
// UserRole values: ADMIN, APPLICANT

model PersonProfile {
  id              Int      @id @default(autoincrement())
  name            String
  title           String?
  bio             String?
  shortBio        String?
  headshot        String?
  email           String?
  googleScholar   String?
  orcid           String?
  linkedin        String?
  github          String?
  cvUrl           String?
  featuredMetrics String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          Int    @id @default(autoincrement())
  institution String
  role        String
  department  String?
  startYear   Int
  endYear     Int?
  type        String // EDUCATION, FACULTY, INDUSTRY, VISITING
  location    String?
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Publication {
  id              Int      @id @default(autoincrement())
  title           String
  authors         String
  year            Int
  journal         String?
  abstract        String?
  doi             String?
  pubmedId        String?
  arxivId         String?
  pdfUrl          String?
  tags            String? // JSON string
  researchLineage String?
  articleType     String?
  featured        Boolean  @default(false)
  curationStatus  String   @default("VERIFIED") // PROVISIONAL, VERIFIED
  sourceCV        String?  // filename of CV this was parsed from

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grant {
  id            Int       @id @default(autoincrement())
  agency        String
  mechanism     String?
  title         String
  role          String?
  amount        Float?
  startDate     DateTime?
  endDate       DateTime?
  collaborators String?
  status        String?
  piName        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Talk {
  id        Int       @id @default(autoincrement())
  title     String
  venue     String?
  host      String?
  city      String?
  country   String?
  date      DateTime?
  talkType  String?
  slidesUrl String?
  videoUrl  String?
  topic     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Honor {
  id          Int     @id @default(autoincrement())
  awardName   String
  year        Int?
  category    String?
  issuer      String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SoftwareResource {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  url            String?
  githubUrl      String?
  screenshotUrl  String?
  relatedPapers  String?
  category       String?
  featured       Boolean  @default(false)
  curationStatus String   @default("VERIFIED") // PROVISIONAL, VERIFIED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patent {
  id              Int     @id @default(autoincrement())
  title           String
  year            Int?
  inventors       String?
  filingInfo      String?
  relatedResearch String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsItem {
  id        Int       @id @default(autoincrement())
  date      DateTime?
  headline  String
  summary   String?
  imageUrl  String?
  link      String?
  pinned    Boolean   @default(false)
  published Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhotoAsset {
  id           Int       @id @default(autoincrement())
  caption      String?
  date         DateTime?
  tags         String? // JSON string
  galleryGroup String?
  sourceUrl    String?
  altText      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InquirySubmission {
  id            Int    @id @default(autoincrement())
  name          String
  email         String
  role          String?
  interestArea  String?
  message       String?
  attachmentUrl String?
  attachments   String? // JSON: [{label, fileName, boxFileId, boxFileUrl}]
  status        String @default("NEW") // NEW, REVIEWED, REPLIED, SHORTLISTED, ACCEPTED, DECLINED, ARCHIVED
  notes         String?

  // AI scoring fields
  aiScore          Int?      // Overall score 1-100
  aiScoreBreakdown String?   // JSON: {communication, resilience, aiFluency, technicalPrep, domainKnowledge, practicalExp}
  aiAnalysis       String?   // AI-generated pros/cons/clarifications text
  aiScoredAt       DateTime?
  manualScore      Int?      // Admin manual override score 1-100
  manualNotes      String?   // Admin notes
  priority         String?   // HIGH, MEDIUM, LOW

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String?
  role     String @default("APPLICANT") // ADMIN, APPLICANT

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Lab Member Management ─────────────────────────────────────────────────

model LabMember {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  role            String   // PhD Student, Postdoc, Research Staff, Intern, Visiting Scholar, etc.
  joinDate        DateTime @default(now())
  status          String   @default("ACTIVE") // ACTIVE, ALUMNI, INACTIVE
  resumeUrl       String?  // Box file URL
  boxFolderId     String?  // Their personal Box folder ID
  boxFolderUrl    String?  // Direct link to their Box folder
  notionPageUrl   String?  // Link to their Notion lab notes
  githubUsername  String?  // GitHub handle
  headshot        String?  // URL to headshot image
  bio             String?
  orcidId         String?  // ORCID identifier

  goals           QuarterlyGoal[]
  projects        ProjectTask[]
  activationCode  ActivationCode?
  papers          MemberPaper[]
  datasets        MemberDataset[]
  tools           MemberTool[]
  compliance      MemberCompliance[]
  watches         MemberWatch[]
  submissions     ContentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTask {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  priority    String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  dueDate     DateTime?
  category    String?   // Research, Writing, Code, Admin, etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ActivationCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique   // random 8-char alphanumeric
  memberId  Int       @unique
  member    LabMember @relation(fields: [memberId], references: [id])
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdBy String   // admin email who generated it

  createdAt DateTime @default(now())
}

model MagicCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String   // 6-digit numeric code
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model QuarterlyGoal {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  quarter     String    // e.g. "2026-Q1"
  title       String
  description String?
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, DEFERRED, CANCELLED
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Member Portal Models ─────────────────────────────────────────────────

model MemberPaper {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  title       String
  authors     String?
  year        Int?
  journal     String?
  url         String?
  doi         String?
  pubmedId    String?
  scholarUrl  String?
  pdfPath     String?
  citation    String?
  notes       String?
  tags        String?   // JSON array
  source      String    @default("MANUAL") // MANUAL, WEB_CLIPPER, PDF_UPLOAD, SCHOLAR
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MemberDataset {
  id             Int       @id @default(autoincrement())
  memberId       Int
  member         LabMember @relation(fields: [memberId], references: [id])
  name           String
  description    String?
  source         String    @default("LOCAL") // LOCAL, DOI, MCP_SERVER, URL
  doi            String?
  url            String?
  filePath       String?
  mcpServer      String?
  format         String?
  size           String?
  tags           String?   // JSON array
  curationStatus String    @default("PROVISIONAL") // PROVISIONAL, VERIFIED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MemberTool {
  id             Int       @id @default(autoincrement())
  memberId       Int
  member         LabMember @relation(fields: [memberId], references: [id])
  name           String
  description    String?
  toolType       String    @default("GITHUB") // GITHUB, JUPYTER, WEB_APP, API, MCP_SERVER, VM, DOCKER, OTHER
  url            String?
  githubRepo     String?
  dockerImage    String?
  apiEndpoint    String?
  mcpServer      String?
  status         String    @default("ACTIVE") // ACTIVE, ARCHIVED, IN_DEVELOPMENT
  tags           String?   // JSON array
  curationStatus String    @default("PROVISIONAL") // PROVISIONAL, VERIFIED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MemberCompliance {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  docType     String    // SOFTWARE_LICENSE, IRB_PROTOCOL, TRAINING_CERT, LICENSE, NDA, DUA, OTHER
  title       String
  description String?
  issuer      String?
  fileUrl     String?
  expiresAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, PENDING, ARCHIVED
  protocolNum String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MemberWatch {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  name        String
  watchType   String    // AUTHOR, KEYWORD, JOURNAL, GITHUB_REPO, TOOL, DATASET
  query       String
  source      String    @default("PUBMED") // PUBMED, SCHOLAR, ARXIV, GITHUB, CUSTOM_URL
  frequency   String    @default("WEEKLY") // DAILY, WEEKLY, MONTHLY
  lastChecked DateTime?
  resultCount Int       @default(0)
  enabled     Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Content Submission / Approval ────────────────────────────────────────

model ContentSubmission {
  id          Int       @id @default(autoincrement())
  memberId    Int
  member      LabMember @relation(fields: [memberId], references: [id])
  contentType String    // PUBLICATION, HONOR, SOFTWARE, PATENT, NEWS
  title       String
  data        String    // JSON with all fields for the content type
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED, REVISION_REQUESTED
  reviewNotes String?   // Admin feedback
  reviewedBy  String?   // Admin email
  reviewedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
